APP_NAME="Tjoerah POS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://YOUR_ACCOUNT.alwaysdata.net

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=single
