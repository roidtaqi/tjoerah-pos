APP_NAME="Tjoerah POS"
APP_ENV=production
APP_KEY_BASE64=GENERATE_A_BASE64_ENCODED_32_BYTE_KEY
APP_DEBUG=false
APP_URL=https://YOUR-SERVICE.b4a.run

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DB_SSLMODE=require

SESSION_DRIVER=cookie
CACHE_STORE=database
QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

JWT_SECRET=GENERATE_A_UNIQUE_JWT_SECRET
JWT_TTL=480

CORS_ALLOWED_ORIGINS=https://roidtaqi.github.io,http://localhost:3000,http://127.0.0.1:3000
SEED_DEMO_DATA=true
PHP_CLI_SERVER_WORKERS=1
