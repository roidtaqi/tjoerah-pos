APP_NAME="Tjoerah POS"
APP_ENV=production
APP_KEY=base64:REPLACE_WITH_PHP_ARTISAN_KEY_GENERATE_SHOW
APP_DEBUG=false
APP_URL=https://tjoerah-pos.onrender.com

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DB_SSLMODE=require

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

JWT_SECRET=REPLACE_WITH_PHP_ARTISAN_JWT_SECRET_SHOW
JWT_TTL=480

CORS_ALLOWED_ORIGINS=*
SEED_DEMO_DATA=true
